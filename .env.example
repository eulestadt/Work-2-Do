# Populi (for scraper)
POPULI_USERNAME=your_populi_email
POPULI_PASSWORD=your_populi_password

# Gemini (for gameplan generation) – get key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: model name (default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# SendGrid (for gameplan email) – get API key from https://sendgrid.com
SENDGRID_API_KEY=
EMAIL_FROM=your_verified_sender@example.com
# EMAIL_TO=phoenix.wang24@sattler.edu

# Timezone for "today" in gameplan – e.g. America/New_York, America/Los_Angeles
# REFERENCE_TIMEZONE=America/New_York
